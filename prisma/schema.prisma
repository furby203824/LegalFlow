generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ============================================================================
// 3.1 TABLE: users
// ============================================================================
model User {
  id            String    @id @default(uuid())
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  // Identity
  username      String    @unique
  passwordHash  String    @map("password_hash")
  mfaSecret     String?   @map("mfa_secret")
  mfaEnabled    Boolean   @default(false) @map("mfa_enabled")

  // Personal
  lastName      String    @map("last_name")
  firstName     String    @map("first_name")
  middleName    String?   @map("middle_name")
  rank          String?
  grade         String?
  edipi         String?
  email         String    @unique

  // Assignment
  unitId        String?   @map("unit_id")
  unit          Unit?     @relation(fields: [unitId], references: [id])
  role          String    // INITIATOR, ADMIN, NJP_AUTHORITY, ACCUSED, APPEAL_AUTHORITY, IPAC_ADMIN, SUITE_ADMIN

  // Status
  isActive      Boolean   @default(true) @map("is_active")
  lastLogin     DateTime? @map("last_login")

  // Relations
  initiatedCases        Case[]              @relation("InitiatedBy")
  njpAuthorityCases     Case[]              @relation("NjpAuthority")
  item16InitiatedCases  Case[]              @relation("Item16InitiatedBy")
  ompfConfirmedCases    Case[]              @relation("OmpfConfirmedBy")
  signatures            Signature[]
  auditLogs             AuditLog[]
  confirmedEntries      Item21Entry[]       @relation("ConfirmedBy")
  remedialActions       RemedialAction[]    @relation("ActionAuthority")
  suspensionResolutions ActiveSuspensionMonitor[] @relation("ResolvedBy")
  ompfValidations       VacationRecord[]    @relation("OmpfValidatedBy")
  generatedDocuments    Document[]          @relation("GeneratedBy")
  correctedPunishments  PunishmentRecord[]  @relation("CorrectedBy")
  vacationCo            VacationRecord[]    @relation("VacationCo")

  @@index([unitId])
  @@index([edipi])
  @@index([role])
  @@map("users")
}

// ============================================================================
// 3.2 TABLE: units
// ============================================================================
model Unit {
  id                String    @id @default(uuid())
  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime  @updatedAt @map("updated_at")

  unitName          String    @map("unit_name")
  unitAbbreviation  String?   @map("unit_abbreviation")
  unitFullString    String    @map("unit_full_string")

  // Hierarchy
  parentUnitId      String?   @map("parent_unit_id")
  parentUnit        Unit?     @relation("UnitHierarchy", fields: [parentUnitId], references: [id])
  childUnits        Unit[]    @relation("UnitHierarchy")

  gcmcaUnitId       String?   @map("gcmca_unit_id")

  isActive          Boolean   @default(true) @map("is_active")

  // Relations
  users             User[]
  accusedProfiles   AccusedProfile[]
  cases             Case[]

  @@index([parentUnitId])
  @@index([gcmcaUnitId])
  @@map("units")
}

// ============================================================================
// 3.3 TABLE: accused_profiles
// ============================================================================
model AccusedProfile {
  id              String    @id @default(uuid())
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  // UPB Items 17-20 / 23-25
  lastName        String    @map("last_name")
  firstName       String    @map("first_name")
  middleName      String?   @map("middle_name")
  rank            String
  grade           String
  edipi           String

  unitId          String?   @map("unit_id")
  unit            Unit?     @relation(fields: [unitId], references: [id])
  unitFullString  String    @map("unit_full_string")

  component       String    @default("ACTIVE") // ACTIVE, SMCR, IRR

  userId          String?   @map("user_id")

  // Relations
  cases           Case[]

  @@index([edipi])
  @@index([unitId])
  @@map("accused_profiles")
}

// ============================================================================
// 3.4 TABLE: cases
// ============================================================================
model Case {
  id              String    @id @default(uuid())
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  // Case identification
  caseNumber      String    @unique @map("case_number")

  // Relationships
  unitId          String    @map("unit_id")
  unit            Unit      @relation(fields: [unitId], references: [id])
  accusedId       String    @map("accused_id")
  accused         AccusedProfile @relation(fields: [accusedId], references: [id])
  initiatedById   String    @map("initiated_by")
  initiatedBy     User      @relation("InitiatedBy", fields: [initiatedById], references: [id])

  // NJP authority
  njpAuthorityId      String?   @map("njp_authority_id")
  njpAuthority        User?     @relation("NjpAuthority", fields: [njpAuthorityId], references: [id])
  njpAuthorityName    String?   @map("njp_authority_name")
  njpAuthorityRank    String?   @map("njp_authority_rank")
  njpAuthorityGrade   String?   @map("njp_authority_grade")
  njpAuthorityEdipi   String?   @map("njp_authority_edipi")
  njpAuthorityTitle   String?   @map("njp_authority_title")
  njpAuthorityUnit    String?   @map("njp_authority_unit")
  commanderGradeLevel String    @map("commander_grade_level") // COMPANY_GRADE, FIELD_GRADE_AND_ABOVE

  // Component
  component       String    @default("ACTIVE")

  // Vessel exception
  vesselException Boolean   @default(false) @map("vessel_exception")

  // Phase tracking
  currentPhase    String    @default("INITIATION") @map("current_phase")
  status          String    @default("INITIATED")

  // Flags
  jaReviewRequired            Boolean @default(false) @map("ja_review_required")
  jaReviewComplete            Boolean @default(false) @map("ja_review_complete")
  jaReviewerName              String? @map("ja_reviewer_name")
  jaReviewDate                String? @map("ja_review_date")
  jaReviewNotes               String? @map("ja_review_notes")

  doublePunishmentChecked     Boolean @default(false) @map("double_punishment_checked")
  jurisdictionConfirmed       Boolean @default(false) @map("jurisdiction_confirmed")
  statuteWarningAcknowledged  Boolean @default(false) @map("statute_warning_acknowledged")

  // Key dates
  offenseDateEarliest         String? @map("offense_date_earliest")
  njpDate                     String? @map("njp_date")
  executionDate               String? @map("execution_date")
  appealFiledDate             String? @map("appeal_filed_date")
  caseFinalDate               String? @map("case_final_date")

  // Item 4 UA/Desertion
  uaApplicable                Boolean @default(false) @map("ua_applicable")
  uaPeriodStart               String? @map("ua_period_start")
  uaPeriodEnd                 String? @map("ua_period_end")
  desertionMarks              String? @map("desertion_marks")

  // Item 10
  dateNoticeToAccused         String? @map("date_notice_to_accused")

  // Item 13
  appealDate                  String? @map("appeal_date")
  appealNotFiled              Boolean @default(false) @map("appeal_not_filed")

  // Item 15
  dateNoticeAppealDecision    String? @map("date_notice_appeal_decision")
  accusedTransferred          Boolean @default(false) @map("accused_transferred")

  // Item 16
  item16InitiatedById         String? @map("item_16_initiated_by")
  item16InitiatedByUser       User?   @relation("Item16InitiatedBy", fields: [item16InitiatedById], references: [id])
  item16SignedDate             String? @map("item_16_signed_date")
  item16UdNumber              String? @map("item_16_ud_number")
  item16Dtd                   String? @map("item_16_dtd")
  ompfScanConfirmed           Boolean @default(false) @map("ompf_scan_confirmed")
  ompfConfirmedById           String? @map("ompf_confirmed_by")
  ompfConfirmedByUser         User?   @relation("OmpfConfirmedBy", fields: [ompfConfirmedById], references: [id])
  ompfConfirmedDate           DateTime? @map("ompf_confirmed_date")

  // Form lock state
  formLocked                  Boolean @default(false) @map("form_locked")

  // Related cases
  parentCaseId                String? @map("parent_case_id")
  parentCase                  Case?   @relation("CaseHierarchy", fields: [parentCaseId], references: [id])
  childCases                  Case[]  @relation("CaseHierarchy")
  isVacationChild             Boolean @default(false) @map("is_vacation_child")

  // Relations
  offenses                    Offense[]
  victims                     Victim[]
  punishmentRecord            PunishmentRecord?
  appealRecord                AppealRecord?
  remedialActions             RemedialAction[]
  item21Entries               Item21Entry[]
  signatures                  Signature[]
  documents                   Document[]
  auditLogs                   AuditLog[]
  suspensionMonitor           ActiveSuspensionMonitor?
  vacationRecordsAsParent     VacationRecord[] @relation("VacationParent")
  vacationRecordsAsChild      VacationRecord[] @relation("VacationChild")

  @@index([unitId])
  @@index([accusedId])
  @@index([status])
  @@index([currentPhase])
  @@index([njpDate])
  @@index([parentCaseId])
  @@map("cases")
}

// ============================================================================
// 3.5 TABLE: offenses
// ============================================================================
model Offense {
  id              String    @id @default(uuid())
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  caseId          String    @map("case_id")
  case_           Case      @relation(fields: [caseId], references: [id], onDelete: Cascade)

  offenseLetter   String    @map("offense_letter") // A-E
  ucmjArticle     String    @map("ucmj_article")
  offenseType     String    @map("offense_type")
  offenseSummary  String    @map("offense_summary")
  offenseDate     String    @map("offense_date")
  offensePlace    String    @map("offense_place")

  finding         String?   // G, NG

  locked          Boolean   @default(false)

  victims         Victim[]

  @@unique([caseId, offenseLetter])
  @@index([caseId])
  @@index([ucmjArticle])
  @@map("offenses")
}

// ============================================================================
// 3.6 TABLE: victims
// ============================================================================
model Victim {
  id              String    @id @default(uuid())
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  caseId          String    @map("case_id")
  case_           Case      @relation(fields: [caseId], references: [id], onDelete: Cascade)
  offenseId       String    @map("offense_id")
  offense         Offense   @relation(fields: [offenseId], references: [id], onDelete: Cascade)

  victimLetter    String    @map("victim_letter") // A-E
  victimStatus    String?   @map("victim_status")
  victimSex       String?   @map("victim_sex")
  victimRace      String?   @map("victim_race")
  victimEthnicity String?   @map("victim_ethnicity")

  locked          Boolean   @default(false)

  @@unique([caseId, victimLetter])
  @@index([caseId])
  @@index([offenseId])
  @@map("victims")
}

// ============================================================================
// 3.7 TABLE: punishment_records
// ============================================================================
model PunishmentRecord {
  id              String    @id @default(uuid())
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  caseId          String    @unique @map("case_id")
  case_           Case      @relation(fields: [caseId], references: [id], onDelete: Cascade)

  // Correctional custody
  corrCustodyDays       Int?    @map("corr_custody_days")

  // Forfeiture
  forfeitureAmount      Int?    @map("forfeiture_amount")
  forfeitureMonths      Int?    @map("forfeiture_months")
  forfeitureTotal       Int?    @map("forfeiture_total")

  // SMCR forfeiture calculation inputs
  smcrDrillPay          Float?  @map("smcr_drill_pay")
  smcrDrills60Days      Int?    @map("smcr_drills_60_days")
  smcrAdBasicPay        Float?  @map("smcr_ad_basic_pay")
  smcrAdDays60          Int?    @map("smcr_ad_days_60")
  smcr60DayStart        String? @map("smcr_60_day_start")
  smcrMaxForfeiture     Int?    @map("smcr_max_forfeiture")

  // Reduction
  reductionImposed      Boolean @default(false) @map("reduction_imposed")
  reductionFromRank     String? @map("reduction_from_rank")
  reductionFromGrade    String? @map("reduction_from_grade")
  reductionToRank       String? @map("reduction_to_rank")
  reductionToGrade      String? @map("reduction_to_grade")
  reductionSuspendedOnly Boolean @default(false) @map("reduction_suspended_only")

  // Extra duties
  extraDutiesDays       Int?    @map("extra_duties_days")

  // Restriction
  restrictionDays       Int?    @map("restriction_days")
  restrictionLocation   String? @map("restriction_location")
  restrictionWithSuspDuty Boolean @default(false) @map("restriction_with_susp_duty")

  // Arrest in quarters
  arrestQuartersDays    Int?    @map("arrest_quarters_days")

  // Detention of pay
  detentionDays         Int?    @map("detention_days")
  detentionAmount       Int?    @map("detention_amount")

  // Admonition/Reprimand
  admonitionReprimand   Boolean @default(false) @map("admonition_reprimand")
  admonitionType        String? @map("admonition_type")

  // Full text
  punishmentText        String  @map("punishment_text")
  punishmentDate        String  @map("punishment_date")

  // Suspension
  suspensionImposed     Boolean @default(false) @map("suspension_imposed")
  suspensionPunishment  String? @map("suspension_punishment")
  suspensionMonths      Int?    @map("suspension_months")
  suspensionStartDate   String? @map("suspension_start_date")
  suspensionEndDate     String? @map("suspension_end_date")
  suspensionRemissionTerms String? @map("suspension_remission_terms")
  suspensionText        String? @map("suspension_text")

  suspensionStatus      String? @map("suspension_status") // NONE, ACTIVE, VACATED, REMITTED
  suspensionVacatedDate String? @map("suspension_vacated_date")
  suspensionRemittedDate String? @map("suspension_remitted_date")

  // JA review thresholds
  jaThresholdArrestQuarters Boolean @default(false) @map("ja_threshold_arrest_quarters")
  jaThresholdCorrCustody    Boolean @default(false) @map("ja_threshold_corr_custody")
  jaThresholdForfeiture     Boolean @default(false) @map("ja_threshold_forfeiture")
  jaThresholdReduction      Boolean @default(false) @map("ja_threshold_reduction")
  jaThresholdExtraDuties    Boolean @default(false) @map("ja_threshold_extra_duties")
  jaThresholdRestriction    Boolean @default(false) @map("ja_threshold_restriction")
  jaThresholdDetention      Boolean @default(false) @map("ja_threshold_detention")
  anyJaThresholdMet         Boolean @default(false) @map("any_ja_threshold_met")

  // Lock state
  locked                Boolean @default(false)
  lastCorrectedById     String? @map("last_corrected_by")
  lastCorrectedBy       User?   @relation("CorrectedBy", fields: [lastCorrectedById], references: [id])
  lastCorrectedAt       DateTime? @map("last_corrected_at")
  correctionNotes       String? @map("correction_notes")

  // Relations
  suspensionMonitor     ActiveSuspensionMonitor?

  @@index([caseId])
  @@index([suspensionStatus])
  @@index([suspensionEndDate])
  @@map("punishment_records")
}

// ============================================================================
// 3.8 TABLE: appeal_records
// ============================================================================
model AppealRecord {
  id              String    @id @default(uuid())
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  caseId          String    @unique @map("case_id")
  case_           Case      @relation(fields: [caseId], references: [id], onDelete: Cascade)

  // Item 12
  appealIntent        String?   @map("appeal_intent") // INTENDS_TO_APPEAL, DOES_NOT_INTEND, REFUSED_TO_SIGN
  item12SignedDate     String?   @map("item_12_signed_date")
  item12SignedById     String?   @map("item_12_signed_by")

  // Item 13
  appealFiled          Boolean   @default(false) @map("appeal_filed")
  appealFiledDate      String?   @map("appeal_filed_date")

  // Five-day stay
  fiveDayClockStart        String?  @map("five_day_clock_start")
  fiveDayAlertSent         Boolean  @default(false) @map("five_day_alert_sent")
  restrictionStayed        Boolean  @default(false) @map("restriction_stayed")
  restrictionStayedDate    String?  @map("restriction_stayed_date")
  extraDutiesStayed        Boolean  @default(false) @map("extra_duties_stayed")
  extraDutiesStayedDate    String?  @map("extra_duties_stayed_date")

  // JA review
  jaReviewRequired       Boolean  @default(false) @map("ja_review_required")
  jaReviewComplete       Boolean  @default(false) @map("ja_review_complete")
  jaReviewerName         String?  @map("ja_reviewer_name")
  jaReviewDate           String?  @map("ja_review_date")
  jaReviewSummary        String?  @map("ja_review_summary")

  // Item 14
  appealAuthorityName          String? @map("appeal_authority_name")
  appealAuthorityRank          String? @map("appeal_authority_rank")
  appealAuthoritySignedDate    String? @map("appeal_authority_signed_date")
  appealOutcome                String? @map("appeal_outcome") // DENIED, DENIED_UNTIMELY, GRANTED_SET_ASIDE, PARTIAL_RELIEF, REDUCTION_SET_ASIDE_ONLY
  appealOutcomeDetail          String? @map("appeal_outcome_detail")

  // Item 15
  appealDecisionNoticeDate         String?  @map("appeal_decision_notice_date")
  accusedTransferredAtNotice       Boolean  @default(false) @map("accused_transferred_at_notice")
  forwardingEndorsementDate        String?  @map("forwarding_endorsement_date")

  // Lock state
  items1314Locked     Boolean  @default(false) @map("items_13_14_locked")

  @@index([caseId])
  @@index([appealOutcome])
  @@map("appeal_records")
}

// ============================================================================
// 3.9 TABLE: remedial_actions
// ============================================================================
model RemedialAction {
  id              String    @id @default(uuid())
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  caseId          String    @map("case_id")
  case_           Case      @relation(fields: [caseId], references: [id], onDelete: Cascade)

  actionType      String    @map("action_type") // SET_ASIDE, MITIGATION, SUSPENSION_OF_EXECUTED, SUSPENSION_REMISSION
  actionDate      String    @map("action_date")

  actionAuthorityName     String  @map("action_authority_name")
  actionAuthorityRole     String? @map("action_authority_role")
  actionAuthorityUserId   String? @map("action_authority_user_id")
  actionAuthority         User?   @relation("ActionAuthority", fields: [actionAuthorityUserId], references: [id])

  punishmentAffected      String  @map("punishment_affected")
  actionDetail            String  @map("action_detail")
  reason                  String?

  mmrpNotificationRequired  Boolean @default(false) @map("mmrp_notification_required")
  mmrpNotificationSent      Boolean @default(false) @map("mmrp_notification_sent")
  mmrpNotificationDate      String? @map("mmrp_notification_date")
  mmrpNotificationContent   String? @map("mmrp_notification_content")

  rightsRestored            Boolean @default(false) @map("rights_restored")
  restorationLanguage       String? @map("restoration_language")

  fourMonthWindowValid      Boolean? @map("four_month_window_valid")
  fourMonthWindowExpiry     String?  @map("four_month_window_expiry")

  item21EntryGenerated      Boolean @default(false) @map("item_21_entry_generated")
  item21EntryText           String? @map("item_21_entry_text")

  @@index([caseId])
  @@index([actionType])
  @@map("remedial_actions")
}

// ============================================================================
// 3.10 TABLE: vacation_records
// ============================================================================
model VacationRecord {
  id              String    @id @default(uuid())
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  parentCaseId    String    @map("parent_case_id")
  parentCase      Case      @relation("VacationParent", fields: [parentCaseId], references: [id])

  childCaseId     String?   @map("child_case_id")
  childCase       Case?     @relation("VacationChild", fields: [childCaseId], references: [id])
  additionalPunishmentContemplated Boolean @default(false) @map("additional_punishment_contemplated")

  vacationDate    String    @map("vacation_date")

  coName          String    @map("co_name")
  coTitle         String    @map("co_title")
  coUserId        String?   @map("co_user_id")
  coUser          User?     @relation("VacationCo", fields: [coUserId], references: [id])
  coSignedDate    String?   @map("co_signed_date")

  originalSuspendedPunishment String @map("original_suspended_punishment")
  originalSuspensionDate      String @map("original_suspension_date")

  vacatedInFull   Boolean   @default(true) @map("vacated_in_full")
  vacatedPortion  String?   @map("vacated_portion")

  triggeringUcmjArticle     String  @map("triggering_ucmj_article")
  triggeringOffenseSummary  String  @map("triggering_offense_summary")
  triggeringOffenseDate     String  @map("triggering_offense_date")

  accusedInformedOfHearing  Boolean @map("accused_informed_of_hearing")
  accusedInformedDate       String? @map("accused_informed_date")
  accusedPermittedToAppear  Boolean @map("accused_permitted_to_appear")
  appearanceNotPracticalReason String? @map("appearance_not_practical_reason")

  proceedingsSummary        String? @map("proceedings_summary")

  figure141Generated        Boolean   @default(false) @map("figure_14_1_generated")
  figure141GeneratedAt      DateTime? @map("figure_14_1_generated_at")
  figure141PocName          String?   @map("figure_14_1_poc_name")
  figure141PocContact       String?   @map("figure_14_1_poc_contact")

  ipacRoutingTriggered      Boolean @default(false) @map("ipac_routing_triggered")
  ipacRoutingDate           String? @map("ipac_routing_date")
  ompfValidationRequired    Boolean @default(true) @map("ompf_validation_required")
  ompfValidated             Boolean @default(false) @map("ompf_validated")
  ompfValidatedById         String? @map("ompf_validated_by")
  ompfValidatedBy           User?   @relation("OmpfValidatedBy", fields: [ompfValidatedById], references: [id])
  ompfValidatedDate         DateTime? @map("ompf_validated_date")

  item21EntryText           String? @map("item_21_entry_text")
  item21EntryConfirmed      Boolean @default(false) @map("item_21_entry_confirmed")

  @@index([parentCaseId])
  @@index([childCaseId])
  @@map("vacation_records")
}

// ============================================================================
// 3.11 TABLE: item_21_entries
// ============================================================================
model Item21Entry {
  id              String    @id @default(uuid())
  createdAt       DateTime  @default(now()) @map("created_at")

  caseId          String    @map("case_id")
  case_           Case      @relation(fields: [caseId], references: [id], onDelete: Cascade)

  entryDate       String    @map("entry_date")
  entrySequence   Int       @map("entry_sequence")

  entryType       String    @map("entry_type")
  // ADDITIONAL_OFFENSE, FORWARDING_RECOMMENDATION, SUSPENSION_VACATED,
  // STAY_RESTRICTION, STAY_EXTRA_DUTIES, APPEAL_DENIED, APPEAL_GRANTED,
  // SET_ASIDE, ADDITIONAL_VICTIM, OTHER

  entryText       String    @map("entry_text")

  systemGenerated Boolean   @default(true) @map("system_generated")
  confirmedById   String?   @map("confirmed_by")
  confirmedBy     User?     @relation("ConfirmedBy", fields: [confirmedById], references: [id])
  confirmedAt     DateTime? @map("confirmed_at")

  locked          Boolean   @default(false)

  @@unique([caseId, entrySequence])
  @@index([caseId])
  @@index([entryType])
  @@index([entryDate])
  @@map("item_21_entries")
}

// ============================================================================
// 3.12 TABLE: signatures
// ============================================================================
model Signature {
  id              String    @id @default(uuid())
  createdAt       DateTime  @default(now()) @map("created_at")

  caseId          String    @map("case_id")
  case_           Case      @relation(fields: [caseId], references: [id], onDelete: Cascade)

  itemNumber      String    @map("item_number") // "2", "3", "9", "11", "12", "14", "16"

  signerRole      String    @map("signer_role")
  signerUserId    String?   @map("signer_user_id")
  signerUser      User?     @relation(fields: [signerUserId], references: [id])
  signerName      String    @map("signer_name")

  signedDate      String    @map("signed_date")
  signedAt        DateTime  @default(now()) @map("signed_at")

  signatureMethod String    @default("ELECTRONIC") @map("signature_method") // ELECTRONIC, PHYSICAL_SCANNED, REFUSED

  refusalNoted    Boolean   @default(false) @map("refusal_noted")
  coSignedInstead Boolean   @default(false) @map("co_signed_instead")

  itemsLocked     String    @default("[]") @map("items_locked") // JSON array

  scanDocumentId  String?   @map("scan_document_id")

  @@index([caseId])
  @@index([itemNumber])
  @@index([signerRole])
  @@map("signatures")
}

// ============================================================================
// 3.13 TABLE: documents
// ============================================================================
model Document {
  id              String    @id @default(uuid())
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  caseId          String    @map("case_id")
  case_           Case      @relation(fields: [caseId], references: [id], onDelete: Cascade)

  documentType    String    @map("document_type")
  // NAVMC_10132, CHARGE_SHEET, OFFICE_HOURS_SCRIPT, FIGURE_14_1,
  // MMRP_NOTIFICATION, VACATION_RECORD, PHYSICAL_SCAN, SET_ASIDE_LETTER, OTHER

  documentVersion Int       @default(1) @map("document_version")

  generatedById   String?   @map("generated_by")
  generatedBy     User?     @relation("GeneratedBy", fields: [generatedById], references: [id])
  generatedAt     DateTime? @map("generated_at")

  filePath        String?   @map("file_path")
  fileSizeBytes   Int?      @map("file_size_bytes")
  fileHash        String?   @map("file_hash")

  distributionEsrb    Boolean @default(false) @map("distribution_esrb")
  distributionOmpf    Boolean @default(false) @map("distribution_ompf")
  distributionFiles   Boolean @default(false) @map("distribution_files")
  distributionMember  Boolean @default(false) @map("distribution_member")

  isCurrent       Boolean   @default(true) @map("is_current")
  supersededById  String?   @map("superseded_by")

  notes           String?

  @@index([caseId])
  @@index([documentType])
  @@map("documents")
}

// ============================================================================
// 3.14 TABLE: audit_logs
// ============================================================================
model AuditLog {
  id              String    @id @default(uuid())
  createdAt       DateTime  @default(now()) @map("created_at")

  caseId          String?   @map("case_id")
  case_           Case?     @relation(fields: [caseId], references: [id])
  tableName       String    @map("table_name")
  recordId        String    @map("record_id")

  action          String    // INSERT, UPDATE, DELETE, SIGN, LOCK, GENERATE, ROUTE, VIEW

  userId          String?   @map("user_id")
  user            User?     @relation(fields: [userId], references: [id])
  userRole        String?   @map("user_role")
  userName        String?   @map("user_name")

  fieldName       String?   @map("field_name")
  oldValue        String?   @map("old_value")
  newValue        String?   @map("new_value")

  ipAddress       String?   @map("ip_address")
  sessionId       String?   @map("session_id")
  notes           String?

  @@index([caseId])
  @@index([tableName])
  @@index([userId])
  @@index([createdAt])
  @@map("audit_logs")
}

// ============================================================================
// 3.15 TABLE: active_suspension_monitor
// ============================================================================
model ActiveSuspensionMonitor {
  id                String    @id @default(uuid())
  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime  @updatedAt @map("updated_at")

  caseId            String    @unique @map("case_id")
  case_             Case      @relation(fields: [caseId], references: [id])
  punishmentRecordId String   @unique @map("punishment_record_id")
  punishmentRecord  PunishmentRecord @relation(fields: [punishmentRecordId], references: [id])

  suspensionStart   String    @map("suspension_start")
  suspensionEnd     String    @map("suspension_end")
  suspendedPunishment String  @map("suspended_punishment")

  monitorStatus     String    @default("ACTIVE") @map("monitor_status") // ACTIVE, VACATED, REMITTED

  daysRemaining     Int?      @map("days_remaining")
  alert30DaySent    Boolean   @default(false) @map("alert_30_day_sent")
  alert7DaySent     Boolean   @default(false) @map("alert_7_day_sent")
  alertExpiredSent  Boolean   @default(false) @map("alert_expired_sent")

  resolvedDate      String?   @map("resolved_date")
  resolvedById      String?   @map("resolved_by")
  resolvedBy        User?     @relation("ResolvedBy", fields: [resolvedById], references: [id])

  @@index([monitorStatus])
  @@index([suspensionEnd])
  @@map("active_suspension_monitor")
}
